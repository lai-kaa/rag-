# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=1234
MYSQL_DATABASE=db

# Ollama 本地配置（LLM_PROVIDER=ollama 时使用）
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen3:8b
EMBED_MODEL=qwen3-embedding:4b

# 模型提供方: deepseek | ollama
LLM_PROVIDER=deepseek

# DeepSeek API 配置（LLM_PROVIDER=deepseek 时使用）
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.3
DEEPSEEK_MAX_TOKENS=4096

# 远程 Embedding API（无需本地模型，SiliconFlow 等 OpenAI 兼容服务）
EMBED_API_KEY=your-embed-api-key
EMBED_API_BASE_URL=https://api.siliconflow.cn/v1
EMBED_API_MODEL=BAAI/bge-m3

# Chroma 向量库
CHROMA_PERSIST_DIR=./chroma_data

# 文件上传目录
UPLOAD_DIR=./uploads

# 日志目录
LOG_DIR=./logs

# JWT 密钥
JWT_SECRET=rag-knowledge-base-secret-key-2026
JWT_EXPIRE_HOURS=72
