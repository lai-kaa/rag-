# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=db
# 云端 MySQL（Render 连接阿里云 PolarDB/RDS）建议设为 true
MYSQL_SSL=false

# CORS 跨域（Render 后端 + Cloudflare Pages 前端必配）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.pages.dev
# 匹配 Cloudflare Pages 预览域名（*.pages.dev）
CORS_ORIGIN_REGEX=https://.*\.(pages\.dev|pages\.cloudflare\.com)$

# Ollama 本地配置（LLM_PROVIDER=ollama 时使用）
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen3:8b
EMBED_MODEL=qwen3-embedding:4b

# 模型提供方: deepseek | ollama
LLM_PROVIDER=deepseek

# DeepSeek API 配置
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.3
DEEPSEEK_MAX_TOKENS=4096

# 远程 Embedding API（SiliconFlow 等）
EMBED_API_KEY=your-embed-api-key
EMBED_API_BASE_URL=https://api.siliconflow.cn/v1
EMBED_API_MODEL=BAAI/bge-m3

# RAG 调优（可选）
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=6
RAG_HISTORY_TURNS=5

CHROMA_PERSIST_DIR=./chroma_data
UPLOAD_DIR=./uploads
LOG_DIR=./logs

JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRE_HOURS=72
